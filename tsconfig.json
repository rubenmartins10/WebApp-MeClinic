{
  "compilerOptions": {
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "declaration": true,
    "strict": false,
    "noImplicitAny": false,
    "target": "ES2020",
    "module": "commonjs"
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": [
    "node_modules",
    "server/node_modules",
    "meclinic-app/client/node_modules",
    "dist",
    "build",
    ".next",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
