# ============================================
# .env.production - Configuração para Produção
# ============================================
# NUNCA commitar este arquivo ao Git!
# Usar variáveis de ambiente na plataforma de hosting

# Database
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=meclinic_db
DB_USER=postgres
DB_PASSWORD=3rubendavid

# ======= EMAIL CONFIGURATION =======
# Email Mode: 'console' (dev) ou 'smtp' (produção)
EMAIL_MODE=smtp

# Mailtrap SMTP (Recomendado para produção baixa/média)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
EMAIL_USER=seu_username_mailtrap
EMAIL_PASS=seu_password_mailtrap

# Alternativa: Gmail (se preferir, mas com cuidado)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# EMAIL_USER=seu_email@gmail.com
# EMAIL_PASS=seu_app_password_16_caracteres

# Alternativa: SendGrid (para volumes altos)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# EMAIL_USER=apikey
# EMAIL_PASS=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ======= JWT SECURITY =======
# MUDE ISTO! Gere uma chave segura (64 caracteres aleatórios)
JWT_SECRET=sua_chave_super_secreta_muito_longa_e_aleatoria_64_caracteres
JWT_EXPIRES_IN=7d

# ======= SSL/TLS para HTTPS =======
# Certificados Let's Encrypt (gratuitos)
SSL_KEY_PATH=/etc/letsencrypt/live/clinica.pt/privkey.pem
SSL_CERT_PATH=/etc/letsencrypt/live/clinica.pt/fullchain.pem

# ======= ENVIRONMENT =======
NODE_ENV=production

# ======= LOGGING =======
LOG_LEVEL=info
