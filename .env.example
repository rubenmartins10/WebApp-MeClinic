# Variáveis de Ambiente - MeClinic
# Copiar para .env e preencher com valores reais
# NUNCA fazer commit do ficheiro .env com dados reais!

# ==========================================
# BASE DE DADOS
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua_senha_postgres
DB_NAME=meclinic
DB_POOL_SIZE=10
DB_SSL=false

# ==========================================
# SERVIDOR
# ==========================================
PORT=5000
NODE_ENV=development
SERVER_HOST=localhost

# ==========================================
# SEGURANÇA
# ==========================================
JWT_SECRET=sua_chave_jwt_muito_segura_aqui_minimo_32_caracteres
JWT_EXPIRES_IN=7d
SESSION_SECRET=sua_chave_de_sessao_secreta_aqui
BCRYPT_ROUNDS=10

# ==========================================
# INFORMAÇÕES DA CLÍNICA
# ==========================================
CLINIC_EMAIL=contato@meclinic.pt
CLINIC_PHONE=+351 XXX XXX XXX
CLINIC_WEBSITE=https://www.meclinic.pt
CLINIC_STREET=Rua Principal
CLINIC_NUMBER=123
CLINIC_CITY=Lisboa
CLINIC_POSTAL_CODE=1000-000
CLINIC_TAX_ID=seu_nif

# ==========================================
# EMAIL / SMTP
# ==========================================
EMAIL_SERVICE=mailtrap
EMAIL_FROM=noreply@meclinic.pt
EMAIL_FROM_NAME=MeClinic

# Mailtrap (desenvolvimento)
MAILTRAP_HOST=live.smtp.mailtrap.io
MAILTRAP_PORT=587
MAILTRAP_USER=seu_user_mailtrap
MAILTRAP_PASS=seu_pass_mailtrap

# SMTP Genérico (produção)
SMTP_HOST=seu-smtp-host.com
SMTP_PORT=587
SMTP_USER=seu_usuario_smtp
SMTP_PASSWORD=sua_senha_smtp
SMTP_SECURE=true

# ==========================================
# FRONTEND REACT
# ==========================================
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_ENV=development
REACT_APP_VERSION=1.0.0

# ==========================================
# INTEGRAÇÕES EXTERNAS
# ==========================================

# Google API (Maps, Calendar, Analytics)
REACT_APP_GOOGLE_API_KEY=sua_chave_google_api
REACT_APP_GOOGLE_ANALYTICS_ID=seu_ga_id

# Stripe (Pagamentos)
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_seu_chave_publica
STRIPE_SECRET_KEY=sk_test_sua_chave_secreta

# PayPal (Pagamentos)
REACT_APP_PAYPAL_CLIENT_ID=seu_client_id_paypal

# SMS Provider
REACT_APP_SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=seu_account_sid
TWILIO_AUTH_TOKEN=seu_auth_token
TWILIO_PHONE_NUMBER=+351XXX

# Sentry (Error Tracking)
REACT_APP_SENTRY_DSN=https://seu_sentry_dsn

# ==========================================
# BACKUP E RESTORE
# ==========================================
BACKUP_PATH=./backups
BACKUP_SCHEDULE=0 2 * * * # 02:00 todas as noites
BACKUP_RETENTION_DAYS=30

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=info
LOG_PATH=./logs
LOG_FILE_SIZE=10m
LOG_FILE_RETENTION=14d

# ==========================================
# DESENVOLVIMENTO
# ==========================================
DEBUG=meclinic:*
ENABLE_REQUEST_LOGGING=true
ENABLE_RESPONSE_LOGGING=true
ENABLE_DATABASE_LOGGING=false
ENABLE_AUTH_LOGGING=true

# ==========================================
# FEATURES / FLAGS
# ==========================================
FEATURE_INVOICES_ENABLED=true
FEATURE_INVOICES_AUTO_SEND=false
FEATURE_SMS_NOTIFICATIONS=false
FEATURE_WHATSAPP_INTEGRATION=false
FEATURE_PATIENT_PORTAL=false

# ==========================================
# CORS
# ==========================================
CORS_ORIGIN=http://localhost:3050
CORS_CREDENTIALS=true

# ==========================================
# API RATE LIMITING
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# CACHE
# ==========================================
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==========================================
# ARQUIVO / FICHEIROS
# ==========================================
FILE_UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,jpg,jpeg,png

# ==========================================
# RELATÓRIOS
# ==========================================
REPORTS_FORMAT=pdf
REPORTS_TIMEZONE=Europe/Lisbon
REPORTS_FISCAL_YEAR_START=January
