{
  "version": 2,
  "builds": [
    {
      "src": "meclinic-app/client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/meclinic-app/client/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
